{
  "name": "agent-webkit",
  "version": "0.1.0",
  "private": true,
  "description": "Two-layer JS SDK + Python reference server exposing the Claude Agent SDK over HTTP+SSE.",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "dev": "pnpm --filter @agent-webkit/chat-demo dev",
    "server": "python examples/server-fastapi/main.py --no-auth",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter \"./packages/core\" --filter \"./packages/react\" build && changeset publish"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@playwright/test": "^1.59.1",
    "typescript": "^5.4.5"
  }
}
